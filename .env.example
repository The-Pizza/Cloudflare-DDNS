# Required
CF_API_TOKEN=cfut_xxx

# Optional
POLL_INTERVAL_SECONDS=60
IPV4_ENDPOINT=https://ipinfo.io/ip
# Set to a plain-text IPv6 echo endpoint (e.g. https://api6.ipify.org) to
# enable AAAA record management. Leave blank to disable IPv6.
IPV6_ENDPOINT=
DATABASE_URL=sqlite:///./data/cloudflare-ddns.db
CONFIG_PATH=/etc/config/records.json
IMPORT_LEGACY_CONFIG=true
ENABLE_ANNOTATION_DISCOVERY=true
ENABLE_TRAEFIK_DISCOVERY=true
ANNOTATION_KEY=cloudflare-ddns.io/dns-name
# Send the session cookie only over HTTPS. Keep true in production; set false
# only for local HTTP development.
SESSION_COOKIE_SECURE=true
LOG_LEVEL=INFO
