# Required
CF_API_TOKEN=cfut_xxx

# Optional
POLL_INTERVAL_SECONDS=60
IPV4_ENDPOINT=https://ipinfo.io/ip
IPV6_ENDPOINT=
DATABASE_URL=sqlite:///./data/cloudflare-ddns.db
CONFIG_PATH=/etc/config/records.json
IMPORT_LEGACY_CONFIG=true
ENABLE_ANNOTATION_DISCOVERY=true
ENABLE_TRAEFIK_DISCOVERY=true
ANNOTATION_KEY=cloudflare-ddns.io/dns-name
LOG_LEVEL=INFO
